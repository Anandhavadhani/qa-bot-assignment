# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/qabot_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qabot_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=5
DB_POOL_MAX=20

# Redis (Caching)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# LLM APIs
# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1000

# Anthropic (Fallback)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Groq (Fallback 2)
GROQ_API_KEY=gsk-your-key-here
GROQ_MODEL=mixtral-8x7b-32768

# Embeddings
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMENSION=1536

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=pdf,docx,csv,txt

# Vector Store
VECTOR_DB_TYPE=postgresql
# Alternative: pinecone, weaviate, qdrant
PINECONE_API_KEY=
PINECONE_INDEX_NAME=qabot
PINECONE_ENVIRONMENT=

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=150
MIN_CHUNK_SIZE=50
MAX_CHUNK_SIZE=2000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Email (Optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Monitoring & Logging
SENTRY_DSN=
LOG_TO_FILE=true
LOG_FILE_PATH=./logs

# Feature Flags
ENABLE_AUTH=true
ENABLE_RATE_LIMITING=true
ENABLE_VECTOR_CACHE=true
ENABLE_DOCUMENT_PREVIEW=true
